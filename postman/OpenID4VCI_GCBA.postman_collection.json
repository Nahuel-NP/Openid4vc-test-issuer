		},
		{
			"name": "Emisión (Protocolo)",
			"item": [
				{
					"name": "Generar Nueva Oferta",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/openid4vci/credential-offer",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"openid4vci",
								"credential-offer"
							]
						},
						"description": "Obtiene un QR y un PIN para iniciar el flujo de emisión."
					},
					"response": []
				},
				{
					"name": "Token Endpoint",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "urn:ietf:params:oauth:grant-type:pre-authorized_code",
									"type": "text"
								},
								{
									"key": "pre-authorized_code",
									"value": "CAMBIAR_POR_CODE_DEL_QR_O_SESS_RECORD",
									"type": "text"
								},
								{
									"key": "user_pin",
									"value": "1234",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/issuer/token",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"issuer",
								"token"
							]
						},
						"description": "Intercambia el pre-authorized_code y el PIN por un Access Token."
					},
					"response": []
				},
				{
					"name": "Credential Endpoint",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"format\": \"vc+sd-jwt\",\n    \"credential_definition\": {\n        \"type\": [\"VerifiableCredential\", \"MyCredentialType\"]\n    },\n    \"proof\": {\n        \"proof_type\": \"jwt\",\n        \"jwt\": \"JWT_POP_FIRMADO_POR_WALLET\"\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/issuer/credential",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"issuer",
								"credential"
							]
						},
						"description": "Solicita la credencial final usando el Access Token y una prueba de posesión (Proof of Possession)."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://tu-ngrok-url.app",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		}
	]
